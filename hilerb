        task.spawn(function()
            while aimEnabled do
                task.wait()
                for _, p in ipairs(game.Players:GetPlayers()) do
                    -- Katili tespit et
                    if p ~= lplayer and p.Character and (p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife")) then
