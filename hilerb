-- 2. DÜZELTİLEN GERÇEK DOKUNMA BOMBASI ITEMI
-- =====================================================================
local BombBtn = createHackerBtn("[2] ENVANTERE BOMBA EKLE", 3)
BombBtn.MouseButton1Click:Connect(function()
    local tool = Instance.new("Tool")
    tool.Name = "Dokunma Bombası 💣"
    tool.RequiresHandle = true
    
    local handle = Instance.new("Part", tool)
    handle.Name = "Handle"
    handle.Size = Vector3.new(1.2, 1.2, 1.2)
    handle.Shape = Enum.PartType.Ball
    handle.Color = Color3.fromRGB(30, 30, 30)
    
    handle.Touched:Connect(function(hit)
        if tool.Parent == lplayer.Character and hit and not hit:IsDescendantOf(lplayer.Character) then
            local exp = Instance.new("Explosion")
            exp.Position = handle.Position
            exp.BlastRadius = 25
            exp.Parent = workspace
            tool:Destroy() -- Patlayınca elinden gider
        end
    end)
    tool.Parent = lplayer.Backpack
end)

