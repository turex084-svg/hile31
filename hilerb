-- SİBER BUTON OLUŞTURUCU
local function createHackerBtn(name, order)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 36)
    btn.Position = UDim2.new(0.05, 0, 0, 0)
    btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    btn.BorderSizePixel = 1
    btn.BorderColor3 = Color3.fromRGB(0, 255, 50)
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(0, 255, 50)
    btn.Font = Enum.Font.Code
    btn.TextSize = 12
    btn.Parent = TabScroll
    btn.LayoutOrder = order
    return btn
end

local lplayer = game.Players.LocalPlayer

-- =====================================================================
-- 1. %100 DÜZELTİLEN YENİ ESP SİSTEMİ
-- =====================================================================
local EspBtn = createHackerBtn("[1] SIBER ESP: KAPALI", 2)
local espActive = false

local function applyEsp(player)
    if player == lplayer then return end
    local function draw(char)
        if char:FindFirstChild("HackerEsp") then char.HackerEsp:Destroy() end
        local f = Instance.new("Folder", char)
        f.Name = "HackerEsp"
        
        local box = Instance.new("BoxHandleAdornment", f)
        box.Size = Vector3.new(4, 6, 4)
        box.AlwaysOnTop = true
        box.ZIndex = 6
        box.Adornee = char:WaitForChild("HumanoidRootPart", 5)
        box.Transparency = 0.6
        box.Color3 = Color3.fromRGB(0, 255, 50)
        
        local bguid = Instance.new("BillboardGui", f)
        bguid.Size = UDim2.new(0, 150, 0, 30)
        bguid.AlwaysOnTop = true
        bguid.StudsOffset = Vector3.new(0, 4, 0)
        bguid.Adornee = char:WaitForChild("HumanoidRootPart", 5)
        
        local tl = Instance.new("TextLabel", bguid)
        tl.Size = UDim2.new(1, 0, 1, 0)
        tl.BackgroundTransparency = 1
        tl.Text = player.Name
        tl.TextColor3 = Color3.fromRGB(0, 255, 50)
        tl.Font = Enum.Font.Code
        tl.TextSize = 12
    end
    if player.Character then draw(player.Character) end
    player.CharacterAdded:Connect(draw)
end

EspBtn.MouseButton1Click:Connect(function()
    espActive = not espActive
    if espActive then
        EspBtn.Text = "[1] SIBER ESP: AÇIK"
        EspBtn.BackgroundColor3 = Color3.fromRGB(0, 40, 10)
        for _, p in ipairs(game.Players:GetPlayers()) do applyEsp(p) end
    else
        EspBtn.Text = "[1] SIBER ESP: KAPALI"
        EspBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        for _, p in ipairs(game.Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("HackerEsp") then p.Character.HackerEsp:Destroy() end
        end
    end
end)

