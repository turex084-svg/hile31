local function createSubBtn(name, parent)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0.92, 0, 0, 36)
    btn.Position = UDim2.new(0.04, 0, 0, 0)
    btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    btn.BorderColor3 = Color3.fromRGB(0, 255, 50)
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(0, 255, 50)
    btn.Font = Enum.Font.Code
    btn.TextSize = 11
    return btn
end

