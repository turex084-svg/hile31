-- Yönlü Uçma Arka Plan Motoru
local fSpeed = 1
local flyVelocity = nil
local flyGyro = nil
local fActive = false

pB.MouseButton1Click:Connect(function() fSpeed = fSpeed + 1; speedValB.Text = tostring(fSpeed) end)
mB.MouseButton1Click:Connect(function() fSpeed = math.max(1, fSpeed - 1); speedValB.Text = tostring(fSpeed) end)

actionFlyB.MouseButton1Click:Connect(function()
    fActive = not fActive
    local char = lplayer.Character
    if fActive and char and char:FindFirstChild("HumanoidRootPart") then
        actionFlyB.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        flyGyro = Instance.new("BodyGyro", char.HumanoidRootPart)
        flyGyro.maxTorque = Vector3.new(9e9, 9e9, 9e9)
        flyVelocity = Instance.new("BodyVelocity", char.HumanoidRootPart)
        flyVelocity.maxForce = Vector3.new(9e9, 9e9, 9e9)
        
        task.spawn(function()
            while fActive and char and char:FindFirstChild("HumanoidRootPart") do
                task.wait()
                char.Humanoid.PlatformStand = true
                flyGyro.cframe = workspace.CurrentCamera.CFrame
                flyVelocity.velocity = workspace.CurrentCamera.CFrame.LookVector * (fSpeed * 20)
            end
        end)
    else
        actionFlyB.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        fActive = false
        if flyVelocity then flyVelocity:Destroy() end
        if flyGyro then flyGyro:Destroy() end
        if char and char:FindFirstChild("Humanoid") then char.Humanoid.PlatformStand = false end
    end
end)

upB.MouseButton1Click:Connect(function() if flyVelocity then flyVelocity.velocity = flyVelocity.velocity + Vector3.new(0, 10, 0) end end)
