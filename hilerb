                        workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, p.Character.HumanoidRootPart.Position)
                    end
                end
            end
        end)
    else
        AimBtn.Text = "MM2 Auto Aim: KAPALI"
        AimBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    end
end)

