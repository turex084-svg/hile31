-- 7. MAP DAĞITAN BOMBA (Sadece Sende Nesneleri Patlatır)
-- =====================================================================
local BombBtn = createButton("Simülasyon Bombası Patlat", Color3.fromRGB(230, 100, 0))
BombBtn.MouseButton1Click:Connect(function()
    local char = lplayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local exp = Instance.new("Explosion")
        exp.Position = char.HumanoidRootPart.Position + Vector3.new(0, 0, 5)
        exp.BlastRadius = 50
        exp.BlastPressure = 1000000 -- Parçaları fırlatır
        exp.Parent = workspace
        
        -- Sadece senin ekranında binaların yerinden oynamasını sağlar (Unanchor)
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and (obj.Position - exp.Position).Magnitude < 50 then
                obj.Anchored = false
            end
        end
    end
end)

