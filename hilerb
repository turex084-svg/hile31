-- 4. UÇMA (FLY) - SORUNSUZ SÜRÜM
-- =====================================================================
local FlyBtn = createHackerBtn("[4] UÇMA (FLY): KAPALI", 5)
local flying = false
FlyBtn.MouseButton1Click:Connect(function()
    flying = not flying
    if flying then
        FlyBtn.Text = "[4] UÇMA (FLY): AÇIK"
        local char = lplayer.Character or lplayer.CharacterAdded:Wait()
        local hrp = char:WaitForChild("HumanoidRootPart")
        local bg = Instance.new("BodyGyro", hrp)
        bg.maxTorque = Vector3.new(9e9, 9e9, 9e9)
        local bv = Instance.new("BodyVelocity", hrp)
        bv.maxForce = Vector3.new(9e9, 9e9, 9e9)
        task.spawn(function()
            while flying and char and hrp do
                task.wait()
                char.Humanoid.PlatformStand = true
                bg.cframe = workspace.CurrentCamera.CFrame
                bv.velocity = workspace.CurrentCamera.CFrame.LookVector * 50
            end
            bv:Destroy()
            bg:Destroy()
            if char:FindFirstChild("Humanoid") then char.Humanoid.PlatformStand = false end
        end)
    else
        FlyBtn.Text = "[4] UÇMA (FLY): KAPALI"
    end
end)

