local CopyBtn = createSubBtn("[🤡] DIŞ GÖRÜNÜMÜ KOPYALA", ScrollTroll)
CopyBtn.MouseButton1Click:Connect(function()
    local tName = TargetBox.Text:lower()
    for _, p in ipairs(game.Players:GetPlayers()) do
        if p.Name:lower():sub(1, #tName) == tName and p.Character and lplayer.Character then
            for _, item in ipairs(lplayer.Character:GetChildren()) do
                if item:IsA("Accessory") or item:IsA("Shirt") or item:IsA("Pants") then item:Destroy() end
            end
            for _, item in ipairs(p.Character:GetChildren()) do
                if item:IsA("Accessory") or item:IsA("Shirt") or item:IsA("Pants") then
                    item:Clone().Parent = lplayer.Character
                end
            end
        end
    end
end)

