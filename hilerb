local function createTabBtn(text, sizeX, posX, targetScroll)
    local btn = Instance.new("TextButton", TabBar)
    btn.Size = UDim2.new(sizeX, 0, 1, 0)
    btn.Position = posX
    btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(0, 255, 50)
    btn.Font = Enum.Font.Code
    btn.TextSize = 10
    btn.MouseButton1Click:Connect(function()
        ScrollMain.Visible = false; ScrollHubs.Visible = false; ScrollTroll.Visible = false; ScrollSoonq.Visible = false
        targetScroll.Visible = true
    end)
end

