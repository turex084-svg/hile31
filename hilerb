-- =====================================================================
-- 1. ADAPTİF MM2 VE GENEL ESP (Katil Kırmızı, Şerif Mavi, Diğerleri Yeşil)
-- =====================================================================
local EspBtn = createButton("ESP: KAPALI", Color3.fromRGB(50, 50, 50))
local espEnabled = false

local function applyESP(player)
    if player == lplayer or not player.Character then return end
    if player.Character:FindFirstChild("HileESP") then player.Character.HileESP:Destroy() end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "HileESP"
    highlight.Parent = player.Character
    highlight.FillOpacity = 0.4
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    
    -- Murder Mystery 2 Rol Kontrolü
    if player.Backpack:FindFirstChild("Knife") or player.Character:FindFirstChild("Knife") then
        highlight.FillColor = Color3.fromRGB(255, 0, 0) -- Katil (Kırmızı)
    elseif player.Backpack:FindFirstChild("Gun") or player.Character:FindFirstChild("Gun") then
        highlight.FillColor = Color3.fromRGB(0, 0, 255) -- Şerif (Mavi)
    else
        highlight.FillColor = Color3.fromRGB(0, 255, 0) -- Masum / Diğer Oyunlar (Yeşil)
    end
end

EspBtn.MouseButton1Click:Connect(function()
    espEnabled = not espEnabled
    if espEnabled then
        EspBtn.Text = "ESP: AÇIK"
        EspBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
        task.spawn(function()
            while espEnabled do
                for _, p in ipairs(game.Players:GetPlayers()) do applyESP(p) end
                task.wait(2)
            end
        end)
    else
        EspBtn.Text = "ESP: KAPALI"
        EspBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        for _, p in ipairs(game.Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("HileESP") then p.Character.HileESP:Destroy() end
        end
    end
end)

-- =====================================================================
-- 2. FLY (UÇMA) - Herkeste Görünür (Server-Side Simülasyonu)
-- =====================================================================
local FlyBtn = createButton("UÇMA (FLY): KAPALI", Color3.fromRGB(50, 50, 50))
local flying = false

FlyBtn.MouseButton1Click:Connect(function()
    flying = not flying
    if flying then
        FlyBtn.Text = "UÇMA (FLY): AÇIK"
        FlyBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        local character = lplayer.Character or lplayer.CharacterAdded:Wait()
        local torso = character:WaitForChild("HumanoidRootPart")
        local bg = Instance.new("BodyGyro", torso)
        bg.maxTorque = Vector3.new(9e9, 9e9, 9e9)
        local bv = Instance.new("BodyVelocity", torso)
        bv.maxForce = Vector3.new(9e9, 9e9, 9e9)
        
        task.spawn(function()
            while flying and character and torso do
                task.wait()
                lplayer.Character.Humanoid.PlatformStand = true
                bg.cframe = workspace.CurrentCamera.CFrame
                bv.velocity = workspace.CurrentCamera.CFrame.LookVector * 60
            end
            bv:Destroy()
            bg:Destroy()
            if lplayer.Character:FindFirstChild("Humanoid") then lplayer.Character.Humanoid.PlatformStand = false end
        end)
    else
        FlyBtn.Text = "UÇMA (FLY): KAPALI"
        FlyBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    end
end)

